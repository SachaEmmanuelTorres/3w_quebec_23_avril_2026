FROM fedora:39
RUN dnf install -y git make gcc-c++ cmake python3-pip && dnf clean all
RUN git clone https://github.com/ggerganov/llama.cpp /app
WORKDIR /app
RUN cmake -B build && cmake --build build --config Release
EXPOSE 8080
# Lancement du serveur natif llama.cpp
CMD ["./build/bin/llama-server", "--host", "0.0.0.0", "--port", "8080", "--model", "/models/granite-2b-test.gguf"]
